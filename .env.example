# Copy to .env and fill in; do not commit .env.
# Optional: subset path (default: data/mt_bench_subset.json)
# MT_BENCH_SUBSET_PATH=

# Required for LLM-as-a-judge: set based on judge provider
# OpenAI (gpt-*): OPENAI_API_KEY
# Anthropic (claude-*): ANTHROPIC_API_KEY
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
JUDGE_MODEL=gpt-4o-mini
# Optional CLI defaults (dashboard passes K and temp explicitly when you use Run Experiment)
# REPEATS=5
# TEMPERATURE=0
# CONDITION_NAME=generic_overall
# METRIC_NAME=
# Condition B: comma-separated list (used if dashboard/CLI does not pass metric_names)
# METRIC_NAMES=accuracy,relevance,completeness
# DATASET_ID=
# SCORE_MIN=0
# SCORE_MAX=100
